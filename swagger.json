{
  "openapi": "3.0.3",
  "info": {
    "title": "Flora Bouquet Shop API",
    "version": "2.0.0",
    "description": "REST API for Flora flower shop — bouquets CRUD with pagination, filtering, photo upload and Swagger UI."
  },
  "servers": [
    { "url": "http://localhost:3000/api", "description": "Local development" },
    { "url": "https://your-render-app.onrender.com/api", "description": "Production (Render)" }
  ],
  "tags": [
    { "name": "Bouquets", "description": "Bouquet CRUD operations" },
    { "name": "Health",   "description": "Liveness probe" }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "responses": {
          "200": { "description": "API is running" }
        }
      }
    },
    "/bouquets": {
      "get": {
        "tags": ["Bouquets"],
        "summary": "List bouquets (paginated, filtered)",
        "parameters": [
          { "name": "page",     "in": "query", "schema": { "type": "integer", "default": 1  } },
          { "name": "limit",    "in": "query", "schema": { "type": "integer", "default": 6  } },
          { "name": "category", "in": "query", "schema": { "type": "string",  "enum": ["bestseller","wedding","seasonal","classic"] } },
          { "name": "search",   "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Paginated bouquet list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data":       { "type": "array",   "items": { "$ref": "#/components/schemas/Bouquet" } },
                    "total":      { "type": "integer" },
                    "page":       { "type": "integer" },
                    "perPage":    { "type": "integer" },
                    "totalPages": { "type": "integer" },
                    "hasMore":    { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Bouquets"],
        "summary": "Create a bouquet",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BouquetCreate" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/Bouquet" } } } } }
          },
          "400": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/bouquets/{id}": {
      "parameters": [
        { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
      ],
      "get": {
        "tags": ["Bouquets"],
        "summary": "Get bouquet by id",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/Bouquet" } } } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "put": {
        "tags": ["Bouquets"],
        "summary": "Update bouquet (at least one field required)",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BouquetUpdate" } } }
        },
        "responses": {
          "200": { "description": "Updated", "content": { "application/json": { "schema": { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/Bouquet" } } } } } },
          "400": { "description": "Empty body or validation error" },
          "404": { "description": "Not found" }
        }
      },
      "delete": {
        "tags": ["Bouquets"],
        "summary": "Delete bouquet",
        "responses": {
          "200": { "description": "Deleted", "content": { "application/json": { "schema": { "type": "object", "properties": { "message": { "type": "string" } } } } } },
          "404": { "description": "Not found" }
        }
      }
    },
    "/bouquets/{id}/favorite": {
      "patch": {
        "tags": ["Bouquets"],
        "summary": "Toggle favorite status",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["favorite"],
                "properties": { "favorite": { "type": "boolean" } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated", "content": { "application/json": { "schema": { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/Bouquet" } } } } } },
          "400": { "description": "Validation error" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/bouquets/{id}/photo": {
      "patch": {
        "tags": ["Bouquets"],
        "summary": "Upload bouquet photo",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["photo"],
                "properties": {
                  "photo": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Photo updated", "content": { "application/json": { "schema": { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/Bouquet" } } } } } },
          "400": { "description": "No file or invalid file type" },
          "404": { "description": "Not found" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Bouquet": {
        "type": "object",
        "properties": {
          "id":          { "type": "integer",  "readOnly": true, "example": 1 },
          "title":       { "type": "string",   "example": "Spring Elegance" },
          "description": { "type": "string",   "example": "A delicate blend of peonies, tulips, and roses." },
          "price":       { "type": "number",   "format": "float", "example": 35.00 },
          "category":    { "type": "string",   "enum": ["bestseller","wedding","seasonal","classic"], "example": "bestseller" },
          "photoURL":    { "type": "string",   "format": "uri",   "nullable": true, "example": "https://example.com/photos/abc.jpg" },
          "favorite":    { "type": "boolean",  "example": false },
          "createdAt":   { "type": "string",   "format": "date-time", "readOnly": true },
          "updatedAt":   { "type": "string",   "format": "date-time", "readOnly": true }
        }
      },
      "BouquetCreate": {
        "type": "object",
        "required": ["title", "description", "price", "category"],
        "properties": {
          "title":       { "type": "string",  "minLength": 2,  "maxLength": 120,  "example": "Spring Elegance" },
          "description": { "type": "string",  "minLength": 5,  "maxLength": 1000, "example": "A delicate blend of peonies, tulips, and roses." },
          "price":       { "type": "number",  "minimum": 0.01, "example": 35.00 },
          "category":    { "type": "string",  "enum": ["bestseller","wedding","seasonal","classic"], "example": "bestseller" },
          "photoURL":    { "type": "string",  "format": "uri",  "example": "https://example.com/photo.jpg" },
          "favorite":    { "type": "boolean", "example": false }
        }
      },
      "BouquetUpdate": {
        "type": "object",
        "description": "At least one field required; body must not be empty.",
        "minProperties": 1,
        "properties": {
          "title":       { "type": "string",  "minLength": 2,  "maxLength": 120 },
          "description": { "type": "string",  "minLength": 5,  "maxLength": 1000 },
          "price":       { "type": "number",  "minimum": 0.01 },
          "category":    { "type": "string",  "enum": ["bestseller","wedding","seasonal","classic"] },
          "photoURL":    { "type": "string",  "format": "uri" },
          "favorite":    { "type": "boolean" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "status":  { "type": "string",  "example": "error" },
          "code":    { "type": "integer", "example": 400 },
          "message": { "type": "string",  "example": "\"title\" is required" }
        }
      }
    }
  }
}

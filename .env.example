# ─── Server ───────────────────────────────────────────────────
PORT=3000
HOST=localhost
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated origins, or * for development
CORS_ORIGIN=*

# ─── PostgreSQL (Render or local) ─────────────────────────────
DB_URL=postgres://user:password@host:5432/flora_db

# ─── Pagination ───────────────────────────────────────────────
DEFAULT_PAGE=1
DEFAULT_LIMIT=6
MAX_LIMIT=50

# ─── Public URL (for building photoURL links) ─────────────────
BASE_URL=http://localhost:3000
